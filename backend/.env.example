# ==========================================
# Agentic Runtime - Local Development Configuration
# ==========================================
# Copy this file to .env and fill in your API keys
# This file is for local development (running backend with uvicorn)

# ==========================================
# Required: LLM Provider Configuration
# ==========================================
# LLM provider: nvidia_nim, openai, anthropic, groq, etc.
LLM_PROVIDER=nvidia_nim

# Chat API key (required)
CHAT_API_KEY=your-api-key-here

# Chat base URL (required for self-hosted/NIM endpoints)
CHAT_BASE_URL=https://integrate.api.nvidia.com/v1

# Chat model identifier
CHAT_MODEL=deepseek-ai/deepseek-v3.2

# Maximum tokens for chat responses
CHAT_MAX_TOKENS=4096

# Thinking/reasoning model (optional, defaults to CHAT_MODEL)
# THINKING_MODEL=deepseek-r1

# Maximum tokens for thinking responses
THINKING_MAX_TOKENS=16000

# ==========================================
# Web Search API Keys
# ==========================================
# Tavily API key for web search (get free key at https://app.tavily.com)
TAVILY_API_KEY=

# Serper.dev API key for Google Search (2,500 free queries/month at https://serper.dev)
SERPER_API_KEY=

# ==========================================
# App Settings
# ==========================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Database path (relative to backend working directory)
DB_PATH=data/agent.db

# ==========================================
# Workspace Configuration
# ==========================================
# Root directory for agent workspace (sandboxed file operations)
WORKSPACE_ROOT=/workspace

# Maximum workspace size in GB
MAX_WORKSPACE_SIZE_GB=10

# ==========================================
# Resource Limits
# ==========================================
# Memory limit in GB (for monitoring)
MEMORY_LIMIT_GB=2

# CPU limit in cores (for monitoring)
CPU_LIMIT_CORES=2

# Maximum concurrent terminal commands
MAX_CONCURRENT_COMMANDS=3

# Maximum concurrent browser sessions
MAX_CONCURRENT_BROWSER_SESSIONS=5

# ==========================================
# Timeout Configuration
# ==========================================
# Command execution timeout in seconds
COMMAND_TIMEOUT_SECONDS=30

# Browser operation timeout in seconds
BROWSER_TIMEOUT_SECONDS=30

# ==========================================
# Feature Flags
# ==========================================
# Enable browser automation capabilities
ENABLE_BROWSER_AUTOMATION=true

# Enable terminal access and command execution
ENABLE_TERMINAL_ACCESS=true

# Enable deep agent with planning and reflection
ENABLE_DEEP_AGENT=true

# ==========================================
# Logging Configuration
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to workspace_root if not absolute)
LOG_FILE=.logs/agent.log

# ==========================================
# Notes
# ==========================================
# - Never commit this file with real API keys
# - Keep .env in .gitignore
# - Restart uvicorn after changing values
# - Check health: curl http://localhost:8000/health
# - Configuration priority: Environment Variables > Workspace Config File > Defaults
# - Workspace config file: /workspace/.agent_config.json (optional)
